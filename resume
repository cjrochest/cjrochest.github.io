  <title>Cornell Rochester Jr — Resume</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #0d0f14;
      --surface: #14181f;
      --surface2: #1c2230;
      --border: rgba(255,255,255,0.07);
      --accent: #4fc3a1;
      --accent2: #f5a623;
      --text: #e8eaed;
      --muted: #7a8499;
      --heading-font: 'DM Serif Display', Georgia, serif;
      --body-font: 'DM Sans', sans-serif;
      --mono-font: 'JetBrains Mono', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--body-font);
      font-size: 15px;
      line-height: 1.7;
      min-height: 100vh;
    }

    /* Background texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 20% -10%, rgba(79,195,161,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 110%, rgba(245,166,35,0.05) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 24px;
      position: relative;
      z-index: 1;
    }

    /* ── HERO ── */
    .hero {
      padding: 80px 0 60px;
      border-bottom: 1px solid var(--border);
    }

    .hero-inner {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 32px;
      flex-wrap: wrap;
    }

    .hero-label {
      font-family: var(--mono-font);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 14px;
      opacity: 0;
      animation: fadeUp 0.5s ease forwards;
    }

    h1 {
      font-family: var(--heading-font);
      font-size: clamp(2.6rem, 6vw, 3.8rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--text);
      opacity: 0;
      animation: fadeUp 0.5s 0.1s ease forwards;
    }

    h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .hero-subtitle {
      font-size: 15px;
      color: var(--muted);
      margin-top: 12px;
      max-width: 420px;
      opacity: 0;
      animation: fadeUp 0.5s 0.2s ease forwards;
    }

    .hero-contacts {
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: flex-end;
      opacity: 0;
      animation: fadeUp 0.5s 0.3s ease forwards;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--mono-font);
      font-size: 12px;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .contact-item:hover { color: var(--accent); }
    .contact-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }

    /* ── SECTION ── */
    section {
      padding: 56px 0 0;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.6s ease forwards;
    }
    section:nth-child(2) { animation-delay: 0.3s; }
    section:nth-child(3) { animation-delay: 0.4s; }
    section:nth-child(4) { animation-delay: 0.5s; }
    section:nth-child(5) { animation-delay: 0.6s; }
    section:nth-child(6) { animation-delay: 0.7s; }
    section:nth-child(7) { animation-delay: 0.8s; }

    .section-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 32px;
    }

    .section-label {
      font-family: var(--mono-font);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .section-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    h2 {
      font-family: var(--heading-font);
      font-size: 1.75rem;
      font-weight: 400;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    /* ── SUMMARY ── */
    .summary-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 2px 8px 8px 2px;
      padding: 24px 28px;
      font-size: 15px;
      color: var(--muted);
      line-height: 1.8;
    }

    /* ── EXPERIENCE ── */
    .exp-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 28px;
      margin-bottom: 20px;
      transition: border-color 0.2s, transform 0.2s;
    }
    .exp-card:hover {
      border-color: rgba(79,195,161,0.25);
      transform: translateY(-2px);
    }

    .exp-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 6px;
    }

    .exp-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
    }

    .exp-company {
      font-family: var(--mono-font);
      font-size: 12px;
      color: var(--accent);
      margin-bottom: 4px;
    }

    .exp-date {
      font-family: var(--mono-font);
      font-size: 11px;
      color: var(--muted);
      white-space: nowrap;
      padding: 4px 10px;
      background: var(--surface2);
      border-radius: 20px;
    }

    .exp-bullets {
      list-style: none;
      margin-top: 14px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .exp-bullets li {
      padding-left: 18px;
      position: relative;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.65;
    }
    .exp-bullets li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 10px;
      width: 5px; height: 1px;
      background: var(--accent);
    }

    /* ── PROJECTS ── */
    .project-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 28px;
      margin-bottom: 20px;
      transition: border-color 0.2s, transform 0.2s;
    }
    .project-card:hover {
      border-color: rgba(245,166,35,0.25);
      transform: translateY(-2px);
    }

    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .project-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
    }

    .project-date {
      font-family: var(--mono-font);
      font-size: 11px;
      color: var(--muted);
    }

    .project-links {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .pill-link {
      font-family: var(--mono-font);
      font-size: 11px;
      padding: 5px 12px;
      border-radius: 20px;
      border: 1px solid rgba(245,166,35,0.3);
      color: var(--accent2);
      text-decoration: none;
      transition: background 0.2s, border-color 0.2s;
    }
    .pill-link:hover {
      background: rgba(245,166,35,0.1);
      border-color: var(--accent2);
    }

    /* ── CERTS GRID ── */
    .certs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 14px;
    }

    .cert-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: border-color 0.2s;
    }
    .cert-card:hover { border-color: rgba(79,195,161,0.3); }

    .cert-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
    }

    .cert-date {
      font-family: var(--mono-font);
      font-size: 11px;
      color: var(--muted);
    }

    .cert-badge {
      display: inline-block;
      margin-top: 4px;
      font-family: var(--mono-font);
      font-size: 10px;
      padding: 3px 8px;
      background: rgba(79,195,161,0.1);
      border: 1px solid rgba(79,195,161,0.2);
      border-radius: 4px;
      color: var(--accent);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ── SKILLS ── */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 14px;
    }

    .skill-row {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px 20px;
    }

    .skill-category {
      font-family: var(--mono-font);
      font-size: 10px;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 6px;
    }

    .skill-items {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── EDUCATION ── */
    .edu-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 600px) { .edu-grid { grid-template-columns: 1fr; } }

    .edu-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 22px;
      transition: border-color 0.2s;
    }
    .edu-card:hover { border-color: rgba(79,195,161,0.25); }

    .edu-school {
      font-weight: 600;
      font-size: 14px;
      color: var(--text);
      margin-bottom: 4px;
    }

    .edu-degree {
      font-size: 13px;
      color: var(--accent);
      margin-bottom: 4px;
    }

    .edu-meta {
      font-family: var(--mono-font);
      font-size: 11px;
      color: var(--muted);
    }

    /* ── FOOTER ── */
    footer {
      padding: 60px 0 40px;
      text-align: center;
      color: var(--muted);
      font-family: var(--mono-font);
      font-size: 11px;
      letter-spacing: 0.1em;
      opacity: 0;
      animation: fadeUp 0.5s 1s ease forwards;
    }

    footer a {
      color: var(--accent);
      text-decoration: none;
    }

    /* ── PRINT BUTTON ── */
    .print-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 20px;
      padding: 10px 20px;
      background: transparent;
      border: 1px solid var(--accent);
      border-radius: 4px;
      color: var(--accent);
      font-family: var(--mono-font);
      font-size: 12px;
      cursor: pointer;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: background 0.2s;
    }
    .print-btn:hover { background: rgba(79,195,161,0.1); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 640px) {
      .hero-inner { flex-direction: column; align-items: flex-start; }
      .hero-contacts { align-items: flex-start; }
    }

    @media print {
      body { background: white; color: #111; }
      body::before { display: none; }
      .print-btn { display: none; }
      .exp-card, .project-card, .cert-card, .skill-row, .edu-card {
        background: white;
        border: 1px solid #ddd;
        break-inside: avoid;
      }
    }
  </style>
</head>
